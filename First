#include <LiquidCrystal.h>

// 引脚：RS, EN, D4, D5, D6, D7
LiquidCrystal lcd(12, 11, 10, 9, 8, 7);

const int trigPin = 4;
const int echoPin = 5;

long echoTime;
float distance;

void setup() {
  Serial.begin(9600);
  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);
  lcd.begin(16, 2);
  lcd.print("SR04 Ready");
  delay(1000);
  lcd.clear();
}

void loop() {
  // 超声波触发
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  echoTime = pulseIn(echoPin, HIGH, 30000);
  distance = echoTime * 0.034 / 2.0;

  lcd.clear();
  lcd.setCursor(0, 0);
  // 过滤近距离盲区，解决cmm乱码
  if(distance < 2 || distance > 400){
    lcd.print("Too Close!");
  }else{
    lcd.print("Dist:");
    lcd.print(distance, 1);
    lcd.print(" cm");
  }
  lcd.setCursor(0, 1);
  lcd.print("HC-SR04 Test");

  Serial.print("Dist:");
  Serial.print(distance, 1);
  Serial.println(" cm");
  delay(400);
}
